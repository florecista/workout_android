<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <!-- Header -->
    <TextView
        android:id="@+id/headerText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Workout Sessions"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Last Session Card -->
    <LinearLayout
        android:id="@+id/lastSessionCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@drawable/card_background"
        app:layout_constraintTop_toBottomOf="@id/headerText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp">

        <TextView
            android:id="@+id/lastSessionLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Last Session"
            android:textSize="14sp"
            android:alpha="0.7"/>

        <TextView
            android:id="@+id/lastSessionDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thu, Mar 21"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp"/>

        <TextView
            android:id="@+id/restDaysText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rested 2 days"
            android:textSize="14sp"
            android:layout_marginTop="2dp"
            android:alpha="0.7"/>

        <!-- Exercises -->
        <LinearLayout
            android:id="@+id/exerciseList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp"/>

    </LinearLayout>

    <!-- Previous Session Card -->
    <LinearLayout
        android:id="@+id/previousSessionCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="@drawable/card_background"
        android:alpha="0.9"
        app:layout_constraintTop_toBottomOf="@id/lastSessionCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp">

        <TextView
            android:id="@+id/previousSessionLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Previous Session"
            android:textSize="13sp"
            android:alpha="0.6"/>

        <TextView
            android:id="@+id/previousSessionDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sun, May 4"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="2dp"/>

        <TextView
            android:id="@+id/previousSessionExercises"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bench Press • Chin Row • Front Raise"
            android:textSize="13sp"
            android:layout_marginTop="4dp"
            android:alpha="0.7"/>

    </LinearLayout>

    <!-- Start Button -->
    <Button
        android:id="@+id/startSessionButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Start New Session"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="24dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>